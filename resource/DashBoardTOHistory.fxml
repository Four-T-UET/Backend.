<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.ScatterChart?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TabPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: transparent;" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ControlHistory">
   <tabs>
      <Tab text="Purchases History">
         <content>
            <HBox spacing="20.0" style="-fx-background-color: #f4f7f6;">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <!-- Left side: Table -->
                  <VBox prefHeight="200.0" prefWidth="400.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                     <children>
                        <Label text="My Purchases" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </Label>
                        <TableView fx:id="tablePurchases" prefHeight="371.0" prefWidth="378.0" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                           <columns>
                              <TableColumn fx:id="itemColPurchases" prefWidth="120.0" text="Item" />
                              <TableColumn fx:id="categoryColPurchases" prefWidth="100.0" text="Category" />
                              <TableColumn fx:id="winpriceColPurchases" prefWidth="100.0" text="Win Price" />
                              <TableColumn fx:id="dateColPurchases" prefWidth="120.0" text="Date" />
                              <TableColumn fx:id="statusColPurchases" prefWidth="100.0" text="Status" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                  <!-- Right side: Details -->
                  <VBox prefWidth="300.0" spacing="20.0" HBox.hgrow="NEVER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <Label text="Statistics &amp; Info" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <VBox alignment="CENTER" spacing="15.0" VBox.vgrow="NEVER">
                            <children>
                                <ImageView fx:id="imagePurchaseIcon" fitHeight="120.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label text="Filter Category:" textFill="#34495e">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="categoryComboPurchases" prefWidth="150.0" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ced4da;" />
                           </children>
                        </HBox>
                        <Region prefHeight="10.0" />
                        <PieChart fx:id="piechartPurchases" title="Purchases by Category" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </content>
      </Tab>

      <Tab text="Selling History">
         <content>
            <HBox spacing="20.0" style="-fx-background-color: #f4f7f6;">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <!-- Left side: Table -->
                  <VBox prefHeight="200.0" prefWidth="400.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                     <children>
                        <Label text="My Active Auctions" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                           <VBox.margin>
                              <Insets bottom="10.0" />
                           </VBox.margin>
                        </Label>
                        <TableView fx:id="tableSelling" prefHeight="371.0" prefWidth="458.0" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                           <columns>
                              <TableColumn fx:id="itemColSelling" prefWidth="120.0" text="Item" />
                              <TableColumn fx:id="indexColSelling" prefWidth="60.0" text="Index" />
                              <TableColumn fx:id="currentbidColSelling" prefWidth="100.0" text="Current Bid" />
                              <TableColumn fx:id="enddateColSelling" prefWidth="120.0" text="End Date" />
                              <TableColumn fx:id="statusColSelling" prefWidth="100.0" text="Status" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                  <!-- Right side: Details -->
                  <VBox prefWidth="300.0" spacing="20.0" HBox.hgrow="NEVER" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <Label text="Auction Analytics" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label text="Item Type:" textFill="#34495e">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="typeComboSelling" prefWidth="150.0" promptText="Select type" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ced4da;" />
                           </children>
                        </HBox>
                        <Region prefHeight="10.0" />
                        <ScatterChart fx:id="scatterchartSelling" title="Bid History" VBox.vgrow="ALWAYS">
                           <xAxis>
                              <CategoryAxis side="BOTTOM" label="Time" />
                           </xAxis>
                           <yAxis>
                              <NumberAxis side="LEFT" label="Current Bid ($)" />
                           </yAxis>
                        </ScatterChart>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </content>
      </Tab>
   </tabs>
</TabPane>
