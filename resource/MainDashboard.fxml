<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ControlDashBoard">
   <top>
      <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label prefHeight="36.0" prefWidth="117.0" text="My Dashboard" HBox.hgrow="SOMETIMES">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Region prefHeight="90.0" prefWidth="0.0" HBox.hgrow="ALWAYS" />
            <Label text="Search">
               <font>
                  <Font size="15.0" />
               </font>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
            <TextField fx:id="searchField" prefHeight="25.0" prefWidth="130.0" promptText="Enter search items" style="-fx-border-radius: 20; -fx-background-radius: 20;" />
            <ComboBox fx:id="categoryComBox" onAction="#chooseCategory" prefHeight="25.0" prefWidth="95.0" promptText="Category" style="-fx-background-color: white; -fx-background-radius: 50; -fx-border-radius: 50;">
               <effect>
                  <Blend />
               </effect>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </ComboBox>
         </children>
         <padding>
            <Insets left="70.0" top="10.0" />
         </padding>
      </HBox>
   </top>
   <left>
      <VBox prefHeight="200.0" prefWidth="70.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="acountBut" mnemonicParsing="false" prefHeight="25.0" prefWidth="85.0" text="Account" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets />
               </VBox.margin></Button>
            <Button fx:id="historyBut" mnemonicParsing="false" prefHeight="25.0" prefWidth="86.0" text="History" />
            <Button fx:id="walletBut" mnemonicParsing="false" prefHeight="25.0" prefWidth="79.0" text="Wallet" VBox.vgrow="ALWAYS" />
            <Button fx:id="sellingBut" mnemonicParsing="false" prefHeight="25.0" prefWidth="79.0" text="Selling" />
            <Button fx:id="settingBut" mnemonicParsing="false" prefHeight="25.0" prefWidth="93.0" text="Setting" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets top="30.0" />
         </BorderPane.margin>
         <children>
            <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="containCards" prefHeight="200.0" prefWidth="200.0">
                     <padding>
                        <Insets left="30.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
   <bottom>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Pagination fx:id="pagination" prefHeight="200.0" prefWidth="200.0">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin></Pagination>
               </children>
            </VBox>
         </children>
      </HBox>
   </bottom>
</BorderPane>
